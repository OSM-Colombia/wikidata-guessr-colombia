[Unit]
Description=Wikidata Guessr Colombia - static web server on port 8001
After=network.target

[Service]
Type=simple
User=guessr
Group=maptimebogota
WorkingDirectory=/home/guessr/wikidata-guessr-colombia
ExecStart=/usr/bin/python3 -m http.server 8001
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
